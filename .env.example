# =============================================================================
# Rayls Cacao — Environment Configuration
# =============================================================================

# -- Privacy Node -------------------------------------------------------------
PRIVACY_NODE_RPC_URL=<PRIVACY_NODE_RPC_URL>
DEPLOYMENT_PROXY_REGISTRY=<DEPLOYMENT_PROXY_REGISTRY>
PRIVACY_NODE_CHAIN_ID=800000

# -- Keys ---------------------------------------------------------------------
DEPLOYER_PRIVATE_KEY=<YOUR_DEPLOYER_PRIVATE_KEY>
REGISTERED_PRIVATE_KEY=<YOUR_REGISTERED_PRIVATE_KEY>

# -- Token Deployment ---------------------------------------------------------
TOKEN_NAME="Cacao Origin Token"
TOKEN_SYMBOL="CACAO"

# -- After Deployment ---------------------------------------------------------
TOKEN_ADDRESS=<DEPLOYED_TOKEN_ADDRESS>

# -- Minting -------------------------------------------------------------------
MINT_RECIPIENT=<YOUR_PRIVATE_CHAIN_ADDRESS>
MINT_AMOUNT=1000

# -- Transfer to Public Chain --------------------------------------------------
TRANSFER_TO=<YOUR_PUBLIC_CHAIN_ADDRESS>
TRANSFER_AMOUNT=100
PUBLIC_CHAIN_ID=7295799

# -- NFT ----------------------------------------------------------------------
NFT_TOKEN_URI=https://example.com/metadata
NFT_NAME="Cacao Harvest NFT"
NFT_SYMBOL="CHARVEST"
NFT_ADDRESS=<DEPLOYED_NFT_ADDRESS>

# -- Public Chain --------------------------------------------------------------
PUBLIC_CHAIN_RPC_URL=<PUBLIC_CHAIN_RPC_URL>

# -- Public Chain Contracts ----------------------------------------------------
ATTESTATION_ADDRESS=<DEPLOYED_ATTESTATION_ADDRESS>
MARKETPLACE_ADDRESS=<DEPLOYED_MARKETPLACE_ADDRESS>

# -- Backend API ---------------------------------------------------------------
BACKEND_URL=<BACKEND_URL>
USER_AUTH_KEY=<USER_AUTH_KEY>
OPERATOR_AUTH_KEY=<OPERATOR_AUTH_KEY>

# -- AI Agent ------------------------------------------------------------------
AI_PROVIDER=openrouter
OPENROUTER_API_KEY=<YOUR_OPENROUTER_API_KEY>
OPENROUTER_MODEL=auto
